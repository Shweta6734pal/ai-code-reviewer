generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  githubId  String   @unique
  username  String
  createdAt DateTime @default(now())
  reviews   Review[]
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  repoUrl   String
  filePath  String
  review    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}


// Tracks GitHub webhook deliveries we've already processed,
// so retries / duplicate subscriptions don't trigger duplicate work.
model WebhookDelivery {
  id         Int      @id @default(autoincrement())
  deliveryId String   @unique // value of the X-GitHub-Delivery header
  event      String
  action     String?
  createdAt  DateTime @default(now())
}