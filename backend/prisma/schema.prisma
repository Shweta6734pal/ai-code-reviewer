generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  githubId  String   @unique
  username  String
  createdAt DateTime @default(now())
  reviews   Review[]
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  repoUrl   String
  filePath  String
  review    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}